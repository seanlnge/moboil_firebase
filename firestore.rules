rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /bookings/{bookingId} {
      // Allow authenticated users to create bookings only
      allow create: if request.auth != null;
      
      // Disallow all reads from the client — use Cloud Functions instead
      allow read: if false;
      
      // Disallow update/delete from the client
      allow update, delete: if false;
    }
  }
}